{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://beacon-production-a89b.up.railway.app/api/:path*"
    },
    {
      "source": "/Beacon/:path*",
      "destination": "https://beacon-production-a89b.up.railway.app/Beacon/:path*"
    },
    {
      "source": "/Risk/:path*",
      "destination": "https://beacon-production-a89b.up.railway.app/Risk/:path*"
    },
    { 
      "source": "/(.*)", 
      "destination": "/index.html" 
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://beacon-production-a89b.up.railway.app;"
        }
      ]
    }
  ]
}